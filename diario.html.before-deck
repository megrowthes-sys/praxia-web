      <div class="mt-5 mono text-[11px] uppercase tracking-widest text-accent">Leer →</div>
    </a>
    -->
  </div>
</section>

<!-- Newsletter / Suscripción -->
<section id="suscribir" class="bg-card border-y border-line">
  <div class="max-w-4xl mx-auto px-6 py-16 md:py-20">
    <div class="grid md:grid-cols-12 gap-10 items-start">
      <div class="md:col-span-5">
        <span class="num">·</span>
        <div class="mono text-[10px] uppercase tracking-widest text-accent mt-3">Suscripción</div>
        <h2 class="serif text-3xl md:text-4xl mt-3 leading-tight">Recibe el próximo Diario.</h2>
        <p class="text-ink-soft mt-5 leading-relaxed">
          Una nota cada vez que publicamos algo en el Diario. Sin newsletter semanal de relleno. Sin promociones. Solo el ensayo cuando está listo, directo al email.
        </p>
        <p class="mono text-[10px] uppercase tracking-widest text-ink-soft mt-6">
          Confidencial · sin compartir · cancelas cuando quieras
        </p>
      </div>
      <div class="md:col-span-7">
        <form class="card p-6 md:p-8" onsubmit="event.preventDefault(); alert('Próximamente: conexión a tu proveedor de email (Resend / Mailchimp / ConvertKit). Por ahora guarda esta página.');">
          <label class="mono text-[10px] uppercase tracking-widest text-ink-soft" for="diario-email">Tu email</label>
          <input id="diario-email" type="email" required placeholder="hola@tuempresa.com" class="w-full mt-3 px-4 py-3 border border-line bg-paper text-ink focus:outline-none focus:border-ink" style="border-radius: 2px;" />
          <label class="mono text-[10px] uppercase tracking-widest text-ink-soft mt-5 block" for="diario-name">Nombre (opcional)</label>
          <input id="diario-name" type="text" placeholder="Tu nombre" class="w-full mt-3 px-4 py-3 border border-line bg-paper text-ink focus:outline-none focus:border-ink" style="border-radius: 2px;" />
          <button type="submit" class="mt-6 inline-flex items-center gap-2 px-5 py-3 text-sm font-medium tracking-wide text-white" style="background: var(--accent); border-radius: 2px;">
            <span>Suscribirme al Diario</span>
            <span aria-hidden="true">→</span>
          </button>
          <p class="mono text-[10px] uppercase tracking-widest text-ink-soft mt-4">
            Al suscribirte aceptas la <a href="privacidad.html" class="underline">política de privacidad</a>.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- CTA editorial -->
<section class="bg-paper">
  <div class="max-w-4xl mx-auto px-6 py-16 md:py-20 text-center">
