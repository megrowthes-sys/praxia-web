<!-- Footer -->
<footer class="border-t border-line bg-paper">
  <div class="max-w-6xl mx-auto px-6 py-10 text-sm text-ink-soft">
    <p class="mono text-[11px] uppercase tracking-widest">Aviso · Caso de demostración</p>
    <p class="mt-2 max-w-3xl">
      "Clínica Lumen", "Dra. Elena Marés" y "Sofia" son ficticios, creados por Praxia Atelier exclusivamente con fines comerciales y de demostración. Cualquier parecido con clínicas, profesionales o productos reales es coincidencia. Las pantallas, cifras y proyecciones son ilustrativas. En un proyecto real todo el contenido se construye y valida con el cliente bajo NDA.
    </p>
  </div>
</footer>

<script>
  // Tabs
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
      document.querySelector(`.panel[data-panel="${tab}"]`).classList.add('active');
    });
  });

  // Simulator
  const fmt = (n) => n.toLocaleString('es-ES');
  function recalcular() {
    const socios = +document.getElementById('rSocios').value;
    const cuota = +document.getElementById('rCuota').value;
    const pract = +document.getElementById('rPract').value;
    const found = +document.getElementById('rFound').value;
    const ticket = +document.getElementById('rTicket').value;

    document.getElementById('vSocios').textContent = fmt(socios);
    document.getElementById('vCuota').textContent = fmt(cuota) + ' €';
    document.getElementById('vPract').textContent = pract;
    document.getElementById('vFound').textContent = found;
    document.getElementById('vTicket').textContent = fmt(ticket) + ' €';

    const recurrentes = socios * cuota;
    const saas = pract * (235 * 12 + 1500); // 235/mes + 1500 anual comisiones
    const vehiculo = found * ticket;
    const arpuActual = 2400;
    const arpuNuevo = (recurrentes + saas/3) / Math.max(socios, 1);
    const ratio = (arpuNuevo / arpuActual);

    document.getElementById('oRecurrentes').textContent = fmt(recurrentes) + ' €';
    document.getElementById('oSaas').textContent = fmt(saas) + ' €';
    document.getElementById('oVehiculo').textContent = fmt(vehiculo) + ' €';
    document.getElementById('oARPU').textContent = '×' + ratio.toFixed(1).replace('.', ',');
  }
  document.querySelectorAll('input[type=range]').forEach(r => r.addEventListener('input', recalcular));
  recalcular();
</script>

<!-- Praxia Chatbox · cargado externo (un solo archivo para todas las páginas) -->
