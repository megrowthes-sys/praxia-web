<!doctype html>
<html lang="es">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Caso · Clínica Lumen · Praxia Atelier</title>
<meta name="description" content="Caso ficticio · Cómo Praxia Atelier transformaría una clínica de medicina integrativa en una plataforma de longevidad con membresía, IA y vehículo de coinversión." />
<script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=IBM+Plex+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1f2e;
    --ink-soft: #44485a;
    --paper: #f4f7f5;       /* verde muy claro · clínica */
    --line: #d8e0db;
    --accent: #2d6a5f;      /* verde sage / clínica */
    --accent-soft: #cee2dc;
    --gold: #b08d3a;
    --gold-soft: #f1e6c5;
    --slate: #4b5d6e;
    --slate-soft: #d2dce4;
    --warm: #b9522e;
    --warm-soft: #f3ddd0;
  }
  html, body {
    background: var(--paper);
    color: var(--ink);
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
  }
  .serif { font-family: "Fraunces", Georgia, serif; font-optical-sizing: auto; }
  .mono { font-family: "JetBrains Mono", ui-monospace, monospace; }
  .text-accent { color: var(--accent); }
  .bg-accent { background: var(--accent); color: #fff; }
  .bg-accent-soft { background: var(--accent-soft); color: var(--accent); }
  .bg-gold-soft { background: var(--gold-soft); color: var(--gold); }
  .bg-slate-soft { background: var(--slate-soft); color: var(--slate); }
  .bg-warm-soft { background: var(--warm-soft); color: var(--warm); }
  .border-line { border-color: var(--line); }
  .pill { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 999px; font-size: 11px; letter-spacing: .08em; text-transform: uppercase; font-weight: 600; }
  .num { font-family: "Fraunces", serif; font-weight: 600; font-size: 14px; color: var(--accent); }
  .underline-soft { background-image: linear-gradient(var(--accent), var(--accent)); background-position: 0 95%; background-repeat: no-repeat; background-size: 100% 2px; padding-bottom: 2px; }
  .grid-bg {
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 56px 56px;
  }
  .card { background: #fff; border: 1px solid var(--line); border-radius: 4px; }
  .card-accent { border-left: 3px solid var(--accent); }
  .card-gold { border-left: 3px solid var(--gold); }
  .card-warm { border-left: 3px solid var(--warm); }
  .arrow { font-family: "JetBrains Mono", monospace; color: var(--accent); }

  /* Tabs */
  .tabs { display: flex; flex-wrap: wrap; gap: 0; border-bottom: 1px solid var(--line); margin-bottom: 24px; }
  .tab-btn {
    padding: 12px 22px;
    border: 0;
    background: transparent;
    color: var(--ink-soft);
    font-family: "IBM Plex Sans", sans-serif;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: all .15s ease;
  }
  .tab-btn:hover { color: var(--ink); }
  .tab-btn.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
    font-weight: 600;
  }
  .panel { display: none; animation: fadein .25s ease; }
  .panel.active { display: block; }
  @keyframes fadein { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }

  /* Mockup frame (browser-like) */
  .browser {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(20, 30, 35, .08);
  }
  .browser-bar {
    background: linear-gradient(to bottom, #f1f3f1, #e8ece9);
    border-bottom: 1px solid var(--line);
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .dot { width: 12px; height: 12px; border-radius: 999px; }
  .browser-url {
    flex: 1;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 5px 12px;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--ink-soft);
    margin-left: 6px;
  }

  /* Mockup landing pública */
  .lumen-mark {
    display: inline-flex; align-items: center; gap: 8px;
  }
  .lumen-symbol { width: 22px; height: 22px; border: 1.5px solid var(--accent); border-radius: 999px; display: flex; align-items: center; justify-content: center; }
  .lumen-symbol::after { content: ""; width: 8px; height: 8px; background: var(--accent); border-radius: 999px; }
  .lumen-name { font-family: "Fraunces", serif; font-size: 16px; letter-spacing: .04em; }

  /* App sidebar */
  .app-side {
    background: #fafbfa;
    border-right: 1px solid var(--line);
    width: 200px;
    padding: 16px 12px;
    flex-shrink: 0;
  }
  .nav-item { padding: 8px 10px; border-radius: 4px; font-size: 13px; color: var(--ink-soft); display: flex; align-items: center; gap: 10px; cursor: pointer; }
  .nav-item.active { background: var(--accent-soft); color: var(--accent); font-weight: 600; }
  .nav-icon { width: 14px; height: 14px; border-radius: 3px; background: currentColor; opacity: .6; }

  /* Health markers */
  .marker { background: #fff; border: 1px solid var(--line); border-radius: 6px; padding: 14px; }
  .marker-num { font-family: "Fraunces", serif; font-size: 28px; line-height: 1; }
  .marker-label { font-family: "JetBrains Mono", monospace; font-size: 9.5px; color: var(--ink-soft); letter-spacing: .12em; text-transform: uppercase; margin-top: 6px; }
  .marker-trend { font-size: 11px; margin-top: 6px; }
  .trend-up { color: var(--accent); }
  .trend-down { color: var(--warm); }

  /* Avatar bubble */
  .bubble {
    background: var(--accent-soft);
    border-radius: 14px 14px 14px 4px;
    padding: 12px 16px;
    font-size: 13px;
    color: var(--ink);
    max-width: 78%;
    line-height: 1.5;
  }
  .bubble-user {
    background: var(--ink);
    color: #fff;
    border-radius: 14px 14px 4px 14px;
    margin-left: auto;
  }

  /* Simulator */
  .slider-wrap { display: flex; flex-direction: column; gap: 4px; }
  .slider-label { display: flex; justify-content: space-between; font-size: 12px; }
  .slider-label .v { font-family: "Fraunces", serif; font-weight: 600; color: var(--accent); }
  input[type=range] { -webkit-appearance: none; height: 4px; background: var(--line); border-radius: 999px; }
  input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; width: 16px; height: 16px; background: var(--accent); border-radius: 999px; cursor: pointer; }

  /* Roadmap */
  .step { background: #fff; border: 1px solid var(--line); padding: 18px; }
  .step-num { font-family: "JetBrains Mono", monospace; font-size: 11px; color: var(--accent); letter-spacing: .12em; text-transform: uppercase; }

  .ribbon {
    display: inline-block;
    background: var(--gold-soft);
    color: var(--gold);
    padding: 3px 10px;
    font-size: 10px;
    letter-spacing: .12em;
    text-transform: uppercase;
    font-weight: 600;
  }
</style>
</head>
<body class="text-ink">

<!-- Top bar -->
<header class="border-b border-line bg-paper sticky top-0 z-30">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="w-7 h-7 border border-ink flex items-center justify-center">
        <span class="serif text-lg leading-none">P</span>
      </div>
      <div class="leading-tight">
        <div class="serif text-lg">Praxia <span class="text-ink-soft">Atelier</span></div>
        <div class="mono text-[10px] text-ink-soft tracking-widest uppercase">Caso · Clínica Lumen</div>
      </div>
    </div>
    <span class="ribbon hidden md:inline-block">Caso ficticio · prototipo accionable</span>
  </div>
</header>

<!-- Hero -->
<section class="relative overflow-hidden border-b border-line">
  <div class="absolute inset-0 grid-bg opacity-30 pointer-events-none"></div>
  <div class="relative max-w-6xl mx-auto px-6 py-20 md:py-24">
    <div class="flex flex-wrap gap-2 mb-6">
      <span class="pill bg-accent-soft">Health-tech · longevidad</span>
      <span class="pill bg-warm-soft">Madrid</span>
      <span class="pill bg-gold-soft">PYME 1,8 M€</span>
      <span class="pill bg-slate-soft">Cápsula 01 + 02</span>
    </div>
    <h1 class="serif text-4xl md:text-6xl leading-[1.05] max-w-4xl">
      Clínica <span class="underline-soft">Lumen</span>
    </h1>
    <p class="serif text-xl md:text-2xl text-ink-soft mt-4 max-w-3xl italic">
      De clínica privada de medicina integrativa a plataforma de longevidad con membresía, avatar de seguimiento y vehículo de coinversión entre pacientes.
    </p>
    <p class="text-base md:text-lg text-ink-soft mt-8 max-w-3xl">
      Caso ficticio creado por Praxia Atelier para mostrar, end-to-end y con mockups navegables, cómo se diseña un ecosistema sobre una clínica consolidada — multiplicando ARPU sin canibalizar la consulta médica y abriendo dos verticales: SaaS para profesionales asociados y vehículo de coinversión privada.
    </p>

    <div class="mt-14 grid grid-cols-2 md:grid-cols-4 gap-px bg-line border border-line">
      <div class="bg-paper p-6">
        <div class="serif text-3xl">×3,4</div>
        <div class="mono text-[11px] uppercase tracking-widest text-ink-soft mt-2">ARPU paciente / año 3</div>
      </div>
      <div class="bg-paper p-6">
        <div class="serif text-3xl">800</div>
        <div class="mono text-[11px] uppercase tracking-widest text-ink-soft mt-2">socios premium objetivo</div>
      </div>
      <div class="bg-paper p-6">
        <div class="serif text-3xl">3,5 M€</div>
        <div class="mono text-[11px] uppercase tracking-widest text-ink-soft mt-2">vehículo coinversión año 2</div>
      </div>
      <div class="bg-paper p-6">
        <div class="serif text-3xl">14 días</div>
        <div class="mono text-[11px] uppercase tracking-widest text-ink-soft mt-2">para entregar el blueprint</div>
      </div>
    </div>
  </div>
</section>

<!-- Brainstorm -->
<section class="bg-white border-b border-line">
  <div class="max-w-6xl mx-auto px-6 py-20 grid md:grid-cols-12 gap-10">
    <div class="md:col-span-4">
      <span class="num">01</span>
      <h2 class="serif text-3xl mt-3">El punto de partida</h2>
      <p class="mono text-[11px] uppercase tracking-widest text-ink-soft mt-3">Brainstorm · Día 0</p>
    </div>
    <div class="md:col-span-8 space-y-5 text-ink-soft text-lg leading-relaxed">
      <p>
        <span class="text-ink font-medium">Clínica Lumen S.L.</span> abrió en 2022 en Madrid. Médica fundadora: <span class="text-ink font-medium">Dra. Elena Marés</span>, internista con especialidad en medicina integrativa y longevidad. Equipo: 6 profesionales (2 médicos, 1 nutricionista, 1 fisioterapeuta, 1 psicóloga, 1 coach). Facturan <span class="text-ink font-medium">1,8 M€/año</span>, paciente medio gasta 2.400 €/año en consultas + analíticas + tratamientos.
      </p>
      <p>
        Lo que está pasando: las clínicas competidoras (Neolife, SHA Wellness, Sanitas Clinic) están profesionalizándose con membresía premium, IA de seguimiento y modelos de suscripción. Elena se está quedando atrás. Tiene <span class="text-ink font-medium">el contenido y la confianza médica</span>, pero le falta la capa de producto digital. Y los pacientes premium le están pidiendo "algo más" — seguimiento entre consultas, comunidad, acceso a tratamientos en otros centros.
      </p>
      <p class="border-l-2 border-accent pl-5 text-ink">
        En la sesión de brainstorm convertimos la clínica en una plataforma con tres palancas que multiplican el ARPU del paciente: <span class="font-medium">membresía Lumen Plus, avatar Sofia para seguimiento entre consultas, y SaaS Lumen Practitioners</span> para que otros médicos certificados se sumen al ecosistema.
      </p>
    </div>
  </div>
</section>

<!-- Diagnóstico -->
<section class="bg-paper border-b border-line">
  <div class="max-w-6xl mx-auto px-6 py-20">
    <span class="num">02</span>
    <h2 class="serif text-3xl md:text-4xl mt-3">Las tres palancas del nuevo modelo</h2>
    <p class="text-ink-soft mt-3 max-w-3xl">Cada palanca por separado podría ser un producto. Juntas forman un sistema en el que cada pieza alimenta a las otras.</p>

    <div class="grid md:grid-cols-3 gap-6 mt-10">
      <div class="card p-7 card-accent">
        <span class="pill bg-accent-soft">Palanca 1</span>
        <h3 class="serif text-xl mt-3">Lumen Plus · membresía premium</h3>
        <p class="text-ink-soft text-sm mt-3">Cuota anual con consultas incluidas, analíticas semestrales, acceso ilimitado al avatar Sofia, descuentos en tratamientos y eventos exclusivos sobre longevidad.</p>
        <p class="text-ink-soft text-sm mt-3"><span class="text-accent font-medium">Por qué funciona:</span> convierte facturación reactiva (paciente paga cuando viene) en recurrente (cuota anual fija). Mejora cash-flow predictible y lifetime value.</p>
      </div>
      <div class="card p-7 card-gold">
        <span class="pill bg-gold-soft">Palanca 2</span>
        <h3 class="serif text-xl mt-3">Sofia · avatar de longevidad</h3>
        <p class="text-ink-soft text-sm mt-3">Avatar con IA que conoce el historial del paciente, le acompaña entre consultas, le recuerda hábitos, le interpreta analíticas y deriva al médico cuando detecta señales relevantes.</p>
        <p class="text-ink-soft text-sm mt-3"><span class="text-accent font-medium">Por qué funciona:</span> aumenta retención (paciente "vinculado" cada día, no sólo en consulta). Genera datos de comportamiento que mejoran el cuidado real.</p>
      </div>
      <div class="card p-7 card-warm">
        <span class="pill bg-warm-soft">Palanca 3</span>
        <h3 class="serif text-xl mt-3">Lumen Practitioners · SaaS B2B</h3>
        <p class="text-ink-soft text-sm mt-3">Otros médicos certificados se suman al ecosistema, atienden pacientes Lumen en sus ciudades, comparten protocolos clínicos. Comisión por sesión + cuota mensual SaaS.</p>
        <p class="text-ink-soft text-sm mt-3"><span class="text-accent font-medium">Por qué funciona:</span> escala la marca Lumen sin abrir clínicas físicas. Convierte la metodología de Elena en producto licenciado.</p>
      </div>
    </div>
  </div>
</section>

<!-- MOCKUPS NAVEGABLES -->
<section class="bg-white border-b border-line">
  <div class="max-w-6xl mx-auto px-6 py-20">
    <span class="num">03</span>
    <h2 class="serif text-3xl md:text-4xl mt-3">El producto, navegable</h2>
    <p class="text-ink-soft mt-3 max-w-3xl">Pulsa cada pestaña para ver el producto desde tres perspectivas: el paciente, el médico y los números. Es el mismo formato y nivel de detalle que entregamos a un cliente, pero aquí construido sobre una clínica ficticia para que puedas verlo abierto.</p>

    <div class="mt-10">
      <div class="tabs">
        <button class="tab-btn active" data-tab="landing">Landing pública</button>
        <button class="tab-btn" data-tab="paciente">Área del paciente</button>
        <button class="tab-btn" data-tab="avatar">Avatar Sofia</button>
        <button class="tab-btn" data-tab="medico">Back office médico</button>
        <button class="tab-btn" data-tab="simulador">Simulador económico</button>
      </div>

      <!-- TAB · LANDING -->
      <div class="panel active" data-panel="landing">
        <div class="browser">
          <div class="browser-bar">
            <span class="dot" style="background:#ff5f57"></span>
            <span class="dot" style="background:#febc2e"></span>
            <span class="dot" style="background:#28c840"></span>
            <span class="browser-url">https://clinicalumen.es</span>
          </div>
          <div style="background: #fafbfa;">
            <!-- Top nav -->
            <div style="border-bottom: 1px solid var(--line); padding: 16px 28px; display: flex; align-items: center; justify-content: space-between; background: #fff;">
              <div class="lumen-mark">
                <span class="lumen-symbol"></span>
                <span class="lumen-name">LUMEN</span>
              </div>
              <div style="display: flex; gap: 24px; font-size: 13px; color: var(--ink-soft);">
                <span>Método</span>
                <span>Profesionales</span>
                <span>Membresía</span>
                <span>Áreas</span>
                <span>Reservar consulta</span>
              </div>
              <button style="background: var(--accent); color: #fff; padding: 8px 16px; border-radius: 4px; font-size: 12px;">Acceder a Lumen Plus</button>
            </div>
            <!-- Hero -->
            <div style="padding: 70px 28px; max-width: 760px;">
              <span class="pill bg-accent-soft">Medicina integrativa de longevidad · Madrid</span>
              <h3 class="serif" style="font-size: 38px; line-height: 1.1; margin-top: 16px;">Tu salud no es un examen anual.</h3>
              <p class="serif" style="font-size: 22px; color: var(--ink-soft); font-style: italic; margin-top: 8px;">Es una conversación que sostenemos contigo cada día.</p>
              <p style="font-size: 14px; color: var(--ink-soft); margin-top: 20px; max-width: 540px;">Lumen Plus es la primera membresía de medicina integrativa con seguimiento continuo, analíticas avanzadas y un avatar clínico que conoce tu historial.</p>
              <div style="margin-top: 28px; display: flex; gap: 12px;">
                <button style="background: var(--accent); color: #fff; padding: 12px 22px; border-radius: 4px; font-size: 13px;">Solicitar invitación</button>
                <button style="border: 1px solid var(--ink); padding: 12px 22px; border-radius: 4px; font-size: 13px;">Ver el método</button>
              </div>
            </div>
            <!-- Bandera de membresia -->
            <div style="border-top: 1px solid var(--line); background: #fff; padding: 32px 28px;">
              <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
                <div>
                  <div class="mono" style="font-size: 10px; color: var(--accent); letter-spacing: .12em; text-transform: uppercase;">Lumen Essential</div>
                  <div class="serif" style="font-size: 22px; margin-top: 6px;">1.200 €/año</div>
                  <p style="font-size: 12px; color: var(--ink-soft); margin-top: 6px;">2 consultas + analítica anual + avatar Sofia.</p>
                </div>
                <div>
                  <div class="mono" style="font-size: 10px; color: var(--accent); letter-spacing: .12em; text-transform: uppercase;">Lumen Plus · más popular</div>
                  <div class="serif" style="font-size: 22px; margin-top: 6px;">3.600 €/año</div>
                  <p style="font-size: 12px; color: var(--ink-soft); margin-top: 6px;">4 consultas + analíticas semestrales + tratamientos con descuento + comunidad.</p>
                </div>
                <div>
                  <div class="mono" style="font-size: 10px; color: var(--accent); letter-spacing: .12em; text-transform: uppercase;">Lumen Founders</div>
                  <div class="serif" style="font-size: 22px; margin-top: 6px;">12.000 €/año</div>
                  <p style="font-size: 12px; color: var(--ink-soft); margin-top: 6px;">Plus + acceso al vehículo de coinversión + voto en protocolos + atención sin lista de espera.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- TAB · PACIENTE -->
      <div class="panel" data-panel="paciente">
        <div class="browser">
          <div class="browser-bar">
            <span class="dot" style="background:#ff5f57"></span>
            <span class="dot" style="background:#febc2e"></span>
            <span class="dot" style="background:#28c840"></span>
            <span class="browser-url">app.clinicalumen.es / mi-salud</span>
          </div>
          <div style="display: flex; min-height: 540px;">
            <!-- Sidebar -->
            <div class="app-side">
              <div class="lumen-mark mb-5" style="margin-bottom: 20px;">
                <span class="lumen-symbol"></span>
                <span class="lumen-name" style="font-size: 14px;">LUMEN</span>
              </div>
              <div class="nav-item active"><span class="nav-icon"></span> Mi salud</div>
              <div class="nav-item"><span class="nav-icon"></span> Sofia</div>
              <div class="nav-item"><span class="nav-icon"></span> Próximas citas</div>
              <div class="nav-item"><span class="nav-icon"></span> Analíticas</div>
              <div class="nav-item"><span class="nav-icon"></span> Tratamientos</div>
              <div class="nav-item"><span class="nav-icon"></span> Comunidad</div>
              <div class="nav-item"><span class="nav-icon"></span> Vehículo · Founders</div>
              <div style="margin-top: 20px; padding-top: 14px; border-top: 1px solid var(--line);">
                <div class="nav-item"><span class="nav-icon"></span> Mi perfil</div>
              </div>
            </div>

            <!-- Content -->
            <div style="flex: 1; padding: 28px;">
              <div style="display: flex; justify-content: space-between; align-items: flex-end; padding-bottom: 18px; border-bottom: 1px solid var(--line);">
                <div>
                  <div class="mono" style="font-size: 10px; color: var(--ink-soft); letter-spacing: .12em; text-transform: uppercase;">Hola, Carlos</div>
                  <h3 class="serif" style="font-size: 24px; margin-top: 4px;">Tu salud esta semana</h3>
                </div>
                <span class="pill bg-accent-soft">Lumen Plus</span>
              </div>

              <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-top: 18px;">
                <div class="marker">
                  <div class="marker-num">7,4 h</div>
                  <div class="marker-label">Sueño profundo</div>
                  <div class="marker-trend trend-up">↑ 0,6 h vs últ. mes</div>
                </div>
                <div class="marker">
                  <div class="marker-num">62</div>
                  <div class="marker-label">FC reposo · ppm</div>
                  <div class="marker-trend trend-up">↓ 4 ppm</div>
                </div>
                <div class="marker">
                  <div class="marker-num">48</div>
                  <div class="marker-label">VO2 máx · ml/kg/min</div>
                  <div class="marker-trend trend-up">↑ percentil 78</div>
                </div>
                <div class="marker">
