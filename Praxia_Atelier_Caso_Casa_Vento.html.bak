<!-- Niveles de inversor -->
<section class="bg-paper border-b border-line">
  <div class="max-w-6xl mx-auto px-6 py-20">
    <span class="num">04</span>
    <h2 class="serif text-3xl md:text-4xl mt-3">Niveles del inversor · estructura del vehículo</h2>
    <p class="text-ink-soft mt-3 max-w-3xl">Tres tramos de entrada con condiciones diferenciadas. Estructura por bloques cerrados de 5–8 operaciones cada uno, no fondo abierto regulado.</p>

    <div class="grid md:grid-cols-3 gap-6 mt-10">
      <div class="card p-7 card-accent">
        <span class="pill bg-accent-soft">Friend</span>
        <h3 class="serif text-2xl mt-3">Vento Friend</h3>
        <div class="serif text-3xl mt-4">desde 50.000 €</div>
        <div class="mono text-[11px] uppercase tracking-widest text-ink-soft mt-1">Por bloque · cierre 36 meses</div>
        <ul class="mt-5 space-y-2 text-sm text-ink-soft">
          <li class="flex gap-3"><span class="arrow">→</span> Acceso a oportunidades del bloque</li>
          <li class="flex gap-3"><span class="arrow">→</span> TIR objetivo 11 %</li>
          <li class="flex gap-3"><span class="arrow">→</span> Reporting trimestral</li>
          <li class="flex gap-3"><span class="arrow">→</span> Avatar Vento básico</li>
        </ul>
      </div>
      <div class="card p-7 card-warm">
        <span class="pill bg-warm-soft">Partner</span>
        <h3 class="serif text-2xl mt-3">Vento Partner</h3>
        <div class="serif text-3xl mt-4">desde 150.000 €</div>
        <div class="mono text-[11px] uppercase tracking-widest text-ink-soft mt-1">Por bloque · cierre 36 meses</div>
        <ul class="mt-5 space-y-2 text-sm text-ink-soft">
          <li class="flex gap-3"><span class="arrow">→</span> Todo lo del Friend +</li>
          <li class="flex gap-3"><span class="arrow">→</span> TIR objetivo 12 %</li>
          <li class="flex gap-3"><span class="arrow">→</span> Visita exclusiva a obras</li>
          <li class="flex gap-3"><span class="arrow">→</span> Avatar Vento completo</li>
          <li class="flex gap-3"><span class="arrow">→</span> Derecho a co-elegir 1 piso/año</li>
        </ul>
      </div>
      <div class="card p-7 card-gold">
        <span class="pill bg-gold-soft">Founder</span>
        <h3 class="serif text-2xl mt-3">Vento Founder</h3>
        <div class="serif text-3xl mt-4">desde 350.000 €</div>
        <div class="mono text-[11px] uppercase tracking-widest text-ink-soft mt-1">Compromiso multi-bloque · 5 años</div>
