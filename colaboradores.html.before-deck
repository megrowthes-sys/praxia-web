      <a href="insights.html" class="hover:text-ink whitespace-nowrap" data-i18n="nav-insights">Insights</a>
      <a href="colaboradores.html" class="text-ink underline underline-offset-4 whitespace-nowrap" data-i18n="nav-colab">Colaboradores</a>
