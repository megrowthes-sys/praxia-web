<script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=IBM+Plex+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1f2e;
    --ink-soft: #44485a;
    --paper: #faf8f3;
    --line: #e6e1d6;
    --accent: #b9522e;
    --accent-soft: #f3ddd0;
    --moss: #4a5d3a;
    --moss-soft: #d8dfcd;
    --gold: #b08d3a;
    --gold-soft: #f1e6c5;
    --slate: #4b5d6e;
    --slate-soft: #d2dce4;
  }
  html, body { background: var(--paper); color: var(--ink); font-family: "IBM Plex Sans", system-ui, -apple-system, sans-serif; -webkit-font-smoothing: antialiased; }
  .serif { font-family: "Fraunces", Georgia, serif; font-optical-sizing: auto; }
  .mono { font-family: "JetBrains Mono", ui-monospace, monospace; }
  .text-ink { color: var(--ink); }
  .text-ink-soft { color: var(--ink-soft); }
  .text-accent { color: var(--accent); }
  .bg-paper { background: var(--paper); }
  .bg-card { background: #ffffff; }
  .bg-accent-soft { background: var(--accent-soft); color: var(--accent); }
  .bg-moss-soft { background: var(--moss-soft); color: var(--moss); }
  .bg-gold-soft { background: var(--gold-soft); color: var(--gold); }
  .bg-slate-soft { background: var(--slate-soft); color: var(--slate); }
  .border-line { border-color: var(--line); }
  .pill { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 999px; font-size: 11px; letter-spacing: .08em; text-transform: uppercase; font-weight: 600; }
  .num { font-family: "Fraunces", serif; font-weight: 600; font-size: 14px; color: var(--accent); }
  .underline-soft { background-image: linear-gradient(var(--accent), var(--accent)); background-position: 0 95%; background-repeat: no-repeat; background-size: 100% 2px; padding-bottom: 2px; }
  .card { background: #fff; border: 1px solid var(--line); border-radius: 4px; transition: transform .2s, box-shadow .2s; }
  .card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px -12px rgba(26,31,46,.12); }
  .card-accent { border-left: 3px solid var(--accent); }
  .card-moss { border-left: 3px solid var(--moss); }
  .card-gold { border-left: 3px solid var(--gold); }
  .card-slate { border-left: 3px solid var(--slate); }
  .form-input, .form-textarea, .form-select {
    width: 100%; padding: 12px 14px; border: 1px solid var(--line);
    background: var(--paper); color: var(--ink); font: inherit;
    border-radius: 2px; transition: border-color .15s;
  }
  .form-input:focus, .form-textarea:focus, .form-select:focus { outline: none; border-color: var(--ink); }
  .form-label { display: block; font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 6px; }
  .pchk { display: flex; align-items: flex-start; gap: 10px; padding: 10px 12px; border: 1px solid var(--line); border-radius: 2px; cursor: pointer; transition: background .15s, border-color .15s; background: #fff; }
  .pchk:hover { background: var(--paper); border-color: var(--ink-soft); }
  .pchk input[type="checkbox"] { margin: 3px 0 0 0; flex-shrink: 0; width: 16px; height: 16px; cursor: pointer; }
  .pchk span { font-size: 13px; line-height: 1.4; flex: 1; }
  .pchk.is-checked { background: var(--accent-soft); border-color: var(--accent); }
</style>
</head>
<body class="text-ink">

<!-- Header -->
<header class="border-b border-line bg-paper sticky top-0 z-30">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="index.html" class="flex items-center gap-3 flex-shrink-0 mr-6 lg:mr-10">
      <div class="border border-ink flex items-center justify-center flex-shrink-0" style="width:28px; height:28px;">
        <span class="serif text-lg leading-none">P</span>
      </div>
      <div class="leading-tight whitespace-nowrap">
        <div class="serif text-lg">Praxia <span class="text-ink-soft">Atelier</span></div>
        <div class="mono text-[10px] text-ink-soft tracking-widest uppercase">Colaboradores</div>
      </div>
    </a>
    <nav class="hidden lg:flex items-center gap-5 text-sm text-ink-soft">
      <a href="index.html#metodo" class="hover:text-ink whitespace-nowrap" data-i18n="nav-metodo">Método</a>
