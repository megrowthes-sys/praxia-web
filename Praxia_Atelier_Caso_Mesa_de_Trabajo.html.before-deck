<footer class="border-t border-line bg-paper">
  <div class="max-w-6xl mx-auto px-6 py-10 text-sm text-ink-soft">
    <p class="mono text-[11px] uppercase tracking-widest">Aviso · Caso founder-cliente</p>
    <p class="mt-2 max-w-3xl">
      Este caso es la demostración del método de Estudio Lúmina aplicado al propio estudio. Las cifras, métricas y nombres de freelances son ilustrativos. La estructura de los 8 departamentos, las cápsulas y la metodología son reales y forman parte del producto comercial de Lúmina.
    </p>
  </div>
</footer>

<script>
  // Tabs
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
      document.querySelector(`.panel[data-panel="${tab}"]`).classList.add('active');
    });
  });

  function goTab(name) {
    const btn = document.querySelector(`.tab-btn[data-tab="${name}"]`);
    if (btn) {
      btn.click();
      document.getElementById('detalle').scrollIntoView({behavior:'smooth'});
    }
  }

  // Simulator finanzas
  const fmt = (n) => Math.round(n).toLocaleString('es-ES');
  function recalc() {
    const sp = +document.getElementById('rSp').value;
    const bl = +document.getElementById('rBl').value;
    const bu = +document.getElementById('rBu').value;
    const pk = +document.getElementById('rPk').value;
    const ga = +document.getElementById('rGa').value;

    document.getElementById('vSp').textContent = sp;
    document.getElementById('vBl').textContent = bl;
    document.getElementById('vBu').textContent = bu;
    document.getElementById('vPk').textContent = pk;
    document.getElementById('vGa').textContent = fmt(ga);

    // Ingresos brutos ficticios para ilustrar el modelo (precios inventados)
    const ing = sp * 2000 + bl * 16000 + bu * (90000/3) + pk * 22000;
    const neto = ing * 0.6;  // tras 25% impuestos + 15% gastos Lúmina
    const margen = neto - ga;
    const fondoEmergencia = margen * 12 * 0.2;  // ahorro acumulado año
    const runway = Math.round(fondoEmergencia / ga);

    document.getElementById('oIng').textContent = fmt(ing) + ' €';
    document.getElementById('oNeto').textContent = fmt(neto) + ' €';
    document.getElementById('oMargen').textContent = fmt(margen) + ' €';
    document.getElementById('oRun').textContent = (runway > 0 ? runway : 0) + ' m';
  }
  document.querySelectorAll('input[type=range]').forEach(r => r.addEventListener('input', recalc));
  recalc();
</script>

<!-- Praxia Chatbox · cargado externo (un solo archivo para todas las páginas) -->
