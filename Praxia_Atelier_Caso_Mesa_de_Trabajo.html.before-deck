<!doctype html>
<html lang="es">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Caso · Mesa de Trabajo · Estudio Lúmina</title>
<meta name="description" content="Caso founder-cliente · Cómo Estudio Lúmina aplica su propio método para operar el estudio: 8 departamentos, ecosistema completo, dashboards y simuladores." />
<script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=IBM+Plex+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1f2e;
    --ink-soft: #44485a;
    --paper: #faf8f3;
    --line: #e6e1d6;
    --accent: #b9522e;       /* terracota Lúmina */
    --accent-soft: #f3ddd0;
    --moss: #4a5d3a;
    --moss-soft: #d8dfcd;
    --gold: #b08d3a;
    --gold-soft: #f1e6c5;
    --slate: #4b5d6e;
    --slate-soft: #d2dce4;
  }
  html, body { background: var(--paper); color: var(--ink); font-family: "IBM Plex Sans", system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
  .serif { font-family: "Fraunces", Georgia, serif; font-optical-sizing: auto; }
  .mono { font-family: "JetBrains Mono", ui-monospace, monospace; }
  .text-accent { color: var(--accent); }
  .bg-accent { background: var(--accent); color: #fff; }
  .bg-accent-soft { background: var(--accent-soft); color: var(--accent); }
  .bg-moss-soft { background: var(--moss-soft); color: var(--moss); }
  .bg-gold-soft { background: var(--gold-soft); color: var(--gold); }
  .bg-slate-soft { background: var(--slate-soft); color: var(--slate); }
  .border-line { border-color: var(--line); }
  .pill { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 999px; font-size: 11px; letter-spacing: .08em; text-transform: uppercase; font-weight: 600; }
  .num { font-family: "Fraunces", serif; font-weight: 600; font-size: 14px; color: var(--accent); }
  .underline-soft { background-image: linear-gradient(var(--accent), var(--accent)); background-position: 0 95%; background-repeat: no-repeat; background-size: 100% 2px; padding-bottom: 2px; }
  .grid-bg { background-image: linear-gradient(var(--line) 1px, transparent 1px), linear-gradient(90deg, var(--line) 1px, transparent 1px); background-size: 56px 56px; }
  .card { background: #fff; border: 1px solid var(--line); border-radius: 4px; }
  .card-accent { border-left: 3px solid var(--accent); }
  .card-moss { border-left: 3px solid var(--moss); }
  .card-gold { border-left: 3px solid var(--gold); }
  .card-slate { border-left: 3px solid var(--slate); }
  .arrow { font-family: "JetBrains Mono", monospace; color: var(--accent); }

  /* Tabs */
  .tabs { display: flex; flex-wrap: wrap; gap: 0; border-bottom: 1px solid var(--line); margin-bottom: 24px; overflow-x: auto; }
  .tab-btn { padding: 12px 18px; border: 0; background: transparent; color: var(--ink-soft); font-family: "IBM Plex Sans", sans-serif; font-size: 13px; font-weight: 500; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: all .15s ease; white-space: nowrap; }
  .tab-btn:hover { color: var(--ink); }
  .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); font-weight: 600; }
  .panel { display: none; animation: fadein .25s ease; }
  .panel.active { display: block; }
  @keyframes fadein { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }

  /* Mockup frame */
  .browser { background: #fff; border: 1px solid var(--line); border-radius: 8px; overflow: hidden; box-shadow: 0 12px 40px rgba(20, 30, 35, .08); }
  .browser-bar { background: linear-gradient(to bottom, #f5f0e6, #ece6d8); border-bottom: 1px solid var(--line); padding: 10px 14px; display: flex; align-items: center; gap: 8px; }
  .dot { width: 12px; height: 12px; border-radius: 999px; }
  .browser-url { flex: 1; background: #fff; border: 1px solid var(--line); border-radius: 4px; padding: 5px 12px; font-family: "JetBrains Mono", monospace; font-size: 11px; color: var(--ink-soft); margin-left: 6px; }

  /* Notion-like layout */
  .notion-side { background: #fbf8f0; border-right: 1px solid var(--line); width: 220px; padding: 14px 10px; flex-shrink: 0; min-height: 540px; }
  .notion-item { padding: 6px 10px; border-radius: 4px; font-size: 13px; color: var(--ink-soft); display: flex; align-items: center; gap: 8px; cursor: pointer; }
  .notion-item.active { background: var(--accent-soft); color: var(--accent); font-weight: 600; }
  .notion-section { font-family: "JetBrains Mono", monospace; font-size: 9.5px; color: var(--ink-soft); letter-spacing: .14em; text-transform: uppercase; padding: 14px 10px 6px; }

  /* Stats card */
  .marker-card { background: #fff; border: 1px solid var(--line); border-radius: 6px; padding: 14px; }
  .marker-num { font-family: "Fraunces", serif; font-size: 24px; line-height: 1; }
  .marker-label { font-family: "JetBrains Mono", monospace; font-size: 9.5px; color: var(--ink-soft); letter-spacing: .12em; text-transform: uppercase; margin-top: 6px; }
  .marker-trend { font-size: 11px; margin-top: 6px; color: var(--accent); }

  /* Kanban */
  .kanban-col { background: #fbf8f0; border-radius: 6px; padding: 10px; min-height: 200px; }
  .kanban-col-title { font-family: "JetBrains Mono", monospace; font-size: 9.5px; letter-spacing: .12em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 8px; }
  .kanban-card { background: #fff; border: 1px solid var(--line); border-radius: 4px; padding: 10px; margin-bottom: 6px; font-size: 12px; }

  /* Property list (notion-like) */
  .prop-row { display: grid; grid-template-columns: 140px 1fr; gap: 10px; padding: 6px 0; font-size: 13px; border-bottom: 1px solid var(--line); }
  .prop-key { color: var(--ink-soft); font-family: "JetBrains Mono", monospace; font-size: 10px; letter-spacing: .12em; text-transform: uppercase; }

  /* Department card */
  .dept-card { background: #fff; border: 1px solid var(--line); border-radius: 6px; padding: 18px; transition: all .2s ease; cursor: pointer; }
  .dept-card:hover { box-shadow: 0 12px 30px rgba(20,30,35,.08); transform: translateY(-2px); border-color: var(--accent); }
  .dept-icon { font-size: 28px; line-height: 1; }
  .dept-num { font-family: "JetBrains Mono", monospace; font-size: 10px; color: var(--accent); letter-spacing: .14em; text-transform: uppercase; margin-bottom: 8px; }

  /* Slider */
  .slider-wrap { display: flex; flex-direction: column; gap: 4px; }
  .slider-label { display: flex; justify-content: space-between; font-size: 12px; }
  .slider-label .v { font-family: "Fraunces", serif; font-weight: 600; color: var(--accent); }
  input[type=range] { -webkit-appearance: none; height: 4px; background: var(--line); border-radius: 999px; }
  input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; width: 16px; height: 16px; background: var(--accent); border-radius: 999px; cursor: pointer; }

  .ribbon { display: inline-block; background: var(--gold-soft); color: var(--gold); padding: 3px 10px; font-size: 10px; letter-spacing: .12em; text-transform: uppercase; font-weight: 600; }
</style>
</head>
<body class="text-ink">

<!-- Top bar -->
<header class="border-b border-line bg-paper sticky top-0 z-30">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="w-7 h-7 border border-ink flex items-center justify-center">
        <span class="serif text-lg leading-none">P</span>
      </div>
      <div class="leading-tight">
        <div class="serif text-lg">Lúmina <span class="text-ink-soft">Atelier</span></div>
        <div class="mono text-[10px] text-ink-soft tracking-widest uppercase">Caso · Mesa de Trabajo</div>
      </div>
    </div>
    <span class="ribbon hidden md:inline-block">Founder-cliente · prototipo accionable</span>
  </div>
</header>

<!-- Hero -->
<section class="relative overflow-hidden border-b border-line">
  <div class="absolute inset-0 grid-bg opacity-30 pointer-events-none"></div>
  <div class="relative max-w-6xl mx-auto px-6 py-20 md:py-24">
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="pill bg-accent-soft">Caso ficticio</span>
      <span class="pill bg-moss-soft">Estudio demostrativo</span>
      <span class="pill bg-gold-soft">Una persona · pool freelance</span>
      <span class="pill bg-slate-soft">Módulos M00–M06</span>
    </div>
    <div class="border-l-4 border-accent bg-accent-soft p-4 mb-6 max-w-3xl">
      <p class="text-sm text-ink"><strong>Caso ficticio.</strong> "Estudio Lúmina" es un consultor inventado que usamos para mostrar cómo se monta un backoffice operativo completo. Cifras, nombres y precios son ilustrativos — no corresponden a ningún cliente ni proveedor real.</p>
    </div>
    <h1 class="serif text-4xl md:text-6xl leading-[1.05] max-w-4xl">
      Mesa de <span class="underline-soft">Trabajo</span>
    </h1>
    <p class="serif text-xl md:text-2xl text-ink-soft mt-4 max-w-3xl italic">
      Cómo Estudio Lúmina aplica su propio método para operar el estudio. 8 departamentos, ecosistema completo, freelances coordinados, todo desde una persona.
    </p>
    <p class="text-base md:text-lg text-ink-soft mt-8 max-w-3xl">
      Caso founder-cliente · El estudio no solo diseña ecosistemas para clientes — los ejecuta sobre sí mismo. Lo que ves aquí es el backoffice operativo de Lúmina: el método de las 8 capas aplicado al propio estudio, listo para crecer sin perder coherencia.
    </p>

    <div class="mt-14 grid grid-cols-2 md:grid-cols-4 gap-px bg-line border border-line">
      <div class="bg-paper p-6"><div class="serif text-3xl">8</div><div class="mono text-[11px] uppercase tracking-widest text-ink-soft mt-2">departamentos</div></div>
      <div class="bg-paper p-6"><div class="serif text-3xl">7</div><div class="mono text-[11px] uppercase tracking-widest text-ink-soft mt-2">cápsulas comerciales</div></div>
      <div class="bg-paper p-6"><div class="serif text-3xl">1</div><div class="mono text-[11px] uppercase tracking-widest text-ink-soft mt-2">persona al frente</div></div>
      <div class="bg-paper p-6"><div class="serif text-3xl">∞</div><div class="mono text-[11px] uppercase tracking-widest text-ink-soft mt-2">pool freelance escalable</div></div>
    </div>
  </div>
</section>

<!-- Vista panorámica · 8 departamentos -->
<section class="bg-white border-b border-line">
  <div class="max-w-6xl mx-auto px-6 py-20">
    <span class="num">01</span>
    <h2 class="serif text-3xl md:text-4xl mt-3">Vista panorámica · los 8 departamentos</h2>
    <p class="text-ink-soft mt-3 max-w-3xl">El estudio funciona como una sola estructura coherente. Cada departamento tiene su propio sistema operativo, sus plantillas y sus métricas — pero todos hablan el mismo idioma. Pulsa cualquier pestaña abajo para ver el detalle.</p>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4 mt-10">
      <div class="dept-card" onclick="goTab('direccion')">
        <div class="dept-icon">📊</div>
        <div class="dept-num mt-3">00 · Dirección</div>
        <h3 class="serif text-lg">General Management</h3>
        <p class="text-sm text-ink-soft mt-2">OKRs trimestrales · plan estratégico anual · calendario maestro · política de decisiones.</p>
      </div>
      <div class="dept-card" onclick="goTab('comercial')">
        <div class="dept-icon">💼</div>
        <div class="dept-num mt-3">01 · Comercial</div>
        <h3 class="serif text-lg">Pipeline y conversión</h3>
        <p class="text-sm text-ink-soft mt-2">Funnel · CRM Leads · scripts · plantillas propuesta · onboarding cliente.</p>
      </div>
      <div class="dept-card" onclick="goTab('marketing')">
        <div class="dept-icon">📣</div>
        <div class="dept-num mt-3">02 · Marketing</div>
        <h3 class="serif text-lg">Captación y contenido</h3>
        <p class="text-sm text-ink-soft mt-2">Calendario editorial · banco ángulos · LinkedIn · newsletter · KPIs.</p>
      </div>
      <div class="dept-card" onclick="goTab('operaciones')">
        <div class="dept-icon">⚙️</div>
        <div class="dept-num mt-3">03 · Operaciones</div>
        <h3 class="serif text-lg">Procesos y SOPs</h3>
        <p class="text-sm text-ink-soft mt-2">Mapa de procesos · 8 SOPs (uno por cápsula) · carpeta cliente · coordinación freelance.</p>
      </div>
      <div class="dept-card" onclick="goTab('producto')">
        <div class="dept-icon">📦</div>
        <div class="dept-num mt-3">04 · Producto</div>
        <h3 class="serif text-lg">Catálogo y método</h3>
        <p class="text-sm text-ink-soft mt-2">7 cápsulas · plantillas reutilizables · banco prompts · método 8 capas.</p>
      </div>
      <div class="dept-card" onclick="goTab('legal')">
        <div class="dept-icon">⚖️</div>
        <div class="dept-num mt-3">05 · Legal</div>
        <h3 class="serif text-lg">Contratos y propiedad</h3>
        <p class="text-sm text-ink-soft mt-2">NDA · 8 contratos por cápsula · acuerdo freelance · IP · cancelación.</p>
      </div>
      <div class="dept-card" onclick="goTab('finanzas')">
        <div class="dept-icon">💰</div>
        <div class="dept-num mt-3">06 · Finanzas</div>
        <h3 class="serif text-lg">Modelo y forecast</h3>
        <p class="text-sm text-ink-soft mt-2">Modelo financiero 18m · pipeline ponderado · política cash · margen real.</p>
      </div>
      <div class="dept-card" onclick="goTab('rrhh')">
        <div class="dept-icon">👥</div>
        <div class="dept-num mt-3">07 · RRHH</div>
        <h3 class="serif text-lg">Pool y aprendices</h3>
        <p class="text-sm text-ink-soft mt-2">Pool freelance · onboarding · tarifas · programa aprendices · contratación interna.</p>
      </div>
    </div>

    <div class="mt-6 grid md:grid-cols-2 gap-4">
      <div class="dept-card" onclick="goTab('partners')" style="border-color: var(--accent);">
        <div class="dept-icon">🤝</div>
        <div class="dept-num mt-3">08 · Partners y referidos</div>
        <h3 class="serif text-lg">Canal indirecto</h3>
        <p class="text-sm text-ink-soft mt-2">Programa partners (despachos, agencias) · programa amigos · pipeline referidos · acuerdo modelo.</p>
      </div>
      <div class="dept-card" onclick="goTab('recursos')" style="border-color: var(--accent);">
        <div class="dept-icon">📚</div>
        <div class="dept-num mt-3">99 · Recursos comunes</div>
        <h3 class="serif text-lg">Biblioteca transversal</h3>
        <p class="text-sm text-ink-soft mt-2">Banco prompts · plantillas · glosario · método 8 capas · casos demo.</p>
      </div>
    </div>
  </div>
</section>

<!-- Detalle departamentos · tabs navegables -->
<section class="bg-paper border-b border-line" id="detalle">
  <div class="max-w-6xl mx-auto px-6 py-20">
    <span class="num">02</span>
    <h2 class="serif text-3xl md:text-4xl mt-3">El backoffice por dentro</h2>
    <p class="text-ink-soft mt-3 max-w-3xl">Cada pestaña muestra cómo está montado un departamento. Datos de ejemplo, dashboards reales, fórmulas que funcionan. Es la versión Lúmina de la consigna que aplicamos a clientes: planos navegables.</p>

    <div class="mt-10">
      <div class="tabs">
        <button class="tab-btn active" data-tab="direccion">📊 Dirección</button>
        <button class="tab-btn" data-tab="comercial">💼 Comercial</button>
        <button class="tab-btn" data-tab="marketing">📣 Marketing</button>
        <button class="tab-btn" data-tab="operaciones">⚙️ Operaciones</button>
        <button class="tab-btn" data-tab="producto">📦 Producto</button>
        <button class="tab-btn" data-tab="legal">⚖️ Legal</button>
        <button class="tab-btn" data-tab="finanzas">💰 Finanzas</button>
        <button class="tab-btn" data-tab="rrhh">👥 RRHH</button>
        <button class="tab-btn" data-tab="partners">🤝 Partners</button>
        <button class="tab-btn" data-tab="recursos">📚 Recursos</button>
      </div>

      <!-- DIRECCIÓN -->
      <div class="panel active" data-panel="direccion">
        <div class="browser">
          <div class="browser-bar"><span class="dot" style="background:#ff5f57"></span><span class="dot" style="background:#febc2e"></span><span class="dot" style="background:#28c840"></span><span class="browser-url">notion.so/lumina/direccion</span></div>
          <div style="padding: 24px 28px; background: #fff;">
            <div class="mono text-[10px] uppercase tracking-widest text-ink-soft">Trimestre actual · Q2 2026</div>
            <h3 class="serif text-2xl mt-2">OKRs Lúmina · abril–junio</h3>

            <div class="mt-6 grid md:grid-cols-3 gap-4">
              <div class="card card-accent p-5">
                <div class="mono text-[10px] uppercase tracking-widest text-accent">Objetivo 1</div>
                <h4 class="serif text-lg mt-2">Cerrar 6 clientes</h4>
                <ul class="mt-4 space-y-2 text-sm text-ink-soft">
                  <li class="flex justify-between"><span>KR1 · 3 Diagnósticos M00</span><strong style="color: var(--accent);">2/3</strong></li>
                  <li class="flex justify-between"><span>KR2 · 2 Planos Maestros M01</span><strong style="color: var(--accent);">1/2</strong></li>
                  <li class="flex justify-between"><span>KR3 · 1 Pack GTM</span><strong style="color: var(--accent);">0/1</strong></li>
                </ul>
              </div>
              <div class="card card-moss p-5">
                <div class="mono text-[10px] uppercase tracking-widest text-accent">Objetivo 2</div>
                <h4 class="serif text-lg mt-2">Posicionamiento marca</h4>
                <ul class="mt-4 space-y-2 text-sm text-ink-soft">
                  <li class="flex justify-between"><span>KR1 · 12 posts LinkedIn</span><strong style="color: var(--accent);">5/12</strong></li>
                  <li class="flex justify-between"><span>KR2 · 1 newsletter mensual</span><strong style="color: var(--accent);">2/3</strong></li>
                  <li class="flex justify-between"><span>KR3 · 50 nuevas conexiones</span><strong style="color: var(--accent);">28/50</strong></li>
                </ul>
              </div>
              <div class="card card-gold p-5">
                <div class="mono text-[10px] uppercase tracking-widest text-accent">Objetivo 3</div>
                <h4 class="serif text-lg mt-2">Pool freelance ×3</h4>
                <ul class="mt-4 space-y-2 text-sm text-ink-soft">
                  <li class="flex justify-between"><span>KR1 · 3 devs validados</span><strong style="color: var(--accent);">1/3</strong></li>
                  <li class="flex justify-between"><span>KR2 · 2 diseñadores</span><strong style="color: var(--accent);">2/2</strong></li>
                  <li class="flex justify-between"><span>KR3 · 1 abogado mercantil</span><strong style="color: var(--accent);">0/1</strong></li>
                </ul>
              </div>
            </div>

            <div class="mt-8 grid md:grid-cols-2 gap-4">
              <div class="card p-5">
                <div class="mono text-[10px] uppercase tracking-widest text-ink-soft">Reporting mes anterior</div>
                <h4 class="serif text-lg mt-1">Lo que aprendí en marzo</h4>
                <ul class="mt-3 text-sm text-ink-soft space-y-1.5">
                  <li>· Diagnóstico Express convierte a Plano Maestro en 50% (mejor que esperado).</li>
                  <li>· Outreach LinkedIn frío funciona peor que referidos (1/40 vs 4/10).</li>
                  <li>· Casos demo navegables son la pieza más decisiva en primera reunión.</li>
                </ul>
              </div>
              <div class="card p-5">
                <div class="mono text-[10px] uppercase tracking-widest text-ink-soft">Decisión del mes</div>
                <h4 class="serif text-lg mt-1">Subir precio del Plano Maestro</h4>
                <p class="text-sm text-ink-soft mt-3">Tras varias firmas sin objeción al precio, se sube la tarifa base un escalón. Próxima revisión: tras 6 firmas más.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- COMERCIAL -->
      <div class="panel" data-panel="comercial">
        <div class="browser">
          <div class="browser-bar"><span class="dot" style="background:#ff5f57"></span><span class="dot" style="background:#febc2e"></span><span class="dot" style="background:#28c840"></span><span class="browser-url">notion.so/lumina/comercial/pipeline</span></div>
          <div style="padding: 24px 28px; background: #fff;">
            <div class="flex justify-between items-end mb-4">
              <div>
                <div class="mono text-[10px] uppercase tracking-widest text-ink-soft">CRM · Pipeline kanban</div>
                <h3 class="serif text-2xl mt-1">Leads en curso</h3>
              </div>
              <div class="flex gap-3 text-sm">
                <span class="pill bg-accent-soft">🔥 4 calientes</span>
                <span class="pill bg-gold-soft">🟡 7 tibios</span>
                <span class="pill bg-slate-soft">❄️ 3 fríos</span>
              </div>
            </div>

            <div class="grid md:grid-cols-5 gap-3 mt-4">
              <div class="kanban-col">
                <div class="kanban-col-title">Nuevo · 5</div>
                <div class="kanban-card"><strong>Carla M.</strong><br><span class="text-ink-soft text-[11px]">Coach wellness · score 65</span></div>
                <div class="kanban-card"><strong>Iván R.</strong><br><span class="text-ink-soft text-[11px]">Real estate · score 92 🔥</span></div>
                <div class="kanban-card"><strong>Rosa V.</strong><br><span class="text-ink-soft text-[11px]">Family office · score 88 🔥</span></div>
              </div>
              <div class="kanban-col">
                <div class="kanban-col-title">Contactado · 3</div>
                <div class="kanban-card"><strong>Pedro G.</strong><br><span class="text-ink-soft text-[11px]">Health-tech · score 72</span></div>
                <div class="kanban-card"><strong>Marina L.</strong><br><span class="text-ink-soft text-[11px]">EdTech · score 58</span></div>
              </div>
